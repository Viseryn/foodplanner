{% extends 'base.html.twig' %}

{% block title %}Recipe{% endblock %}

{% block main %}
<div class="flex">
    <div class="rounded-b-3xl md:rounded-3xl shadow-md border border-gray-200  bg-white mx-auto p-6 md:mt-10 lg:mt-20 w-full md:w-1/2">
        <div class="text-xl font-semibold text-violet-700 mb-6">
            Recipe: {{ recipe.title }}
        </div>

        <div class="text-md font-semibold">
            Ingredients for {{ recipe.portionSize }} portions
        </div>
        <ul class="list-inside list-disc">
        {% for ingredient in recipe.ingredients %}
            <li>
                <a href="{{ path('app_ingredient_edit', {'id': ingredient.id}) }}">
                    {{ ingredient.quantityValue }} 
                    {{ ingredient.quantityUnit }} 
                    {{ ingredient }}
                </a>
            </li>
        {% endfor %}
        </ul>

        <div class="text-md font-semibold mt-6">
            Instructions
        </div>
        <ul class="list-inside list-decimal">
        {% for instruction in recipe.instructions %}
            <li>
                <a href="{{ path('app_instruction_edit', {'id': instruction.id}) }}">
                    {{ instruction }}
                </a>
            </li>
        {% endfor %}
        </ul>
    </div>
</div>

<div class="flex">
    <div class="mx-auto p-6 md:mb-10 lg:mb-20 w-full md:w-1/2">
        <a href="{{ path('app_ingredient_new_for_recipe', {'recipeId': recipe.id}) }}" class="transition duration-700 text-slate-400 hover:text-slate-600">Add ingredient</a> <br />
        <a href="{{ path('app_instruction_new_for_recipe', {'recipeId': recipe.id}) }}" class="transition duration-700 text-slate-400 hover:text-slate-600">Add instruction</a> <br />
        <a href="{{ path('app_recipe_edit', {'id': recipe.id}) }}" class="transition duration-700 text-slate-400 hover:text-slate-600">Edit recipe</a>
        {# {{ include('recipe/_delete_form.html.twig') }} #}

        <form method="post" action="{{ path('app_recipe_delete', {'id': recipe.id}) }}" onsubmit="return confirm('Are you sure you want to delete this recipe?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ recipe.id) }}">
            <button class="transition duration-700 text-slate-400 hover:text-slate-600">Delete recipe</button>
        </form>
    </div> 
</div>
{% endblock %}
