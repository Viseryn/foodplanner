{# templates/recipe/new.html.twig #}

{% extends 'base.html.twig' %}
{% set heading = 'Add new recipe' %}

{% block title %}{{ heading }}{% endblock %}

{% block load_sidebar %}loadSidebar('recipes');{% endblock %}

{% block main %}
    {{ include('component/_heading.html.twig', {heading: heading}) }}

    {{ form_start(form, {attr: {'class': 'grid grid-cols-1 lg:grid-cols-2 gap-10 gap-y-0 max-w-[400px] lg:max-w-[900px]'}}) }}
        <div>
            {{ form_row(form.title, {
                row_attr: {'class': inputRowClass},
                label_attr: {'class': inputLabelClass},
                attr: {'class': inputClass},
            }) }}

            {{ form_row(form.portionSize, {
                row_attr: {'class': inputRowClass},
                label_attr: {'class': inputLabelClass, 'id': 'portionSizeOutput'},
                attr: {'class': 'w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer', 'oninput': 'getElementById("portionSizeOutput").innerHTML = "Portions: " + this.value'},
                label: 'Portions: 1',
            }) }}

            <div>
                <div class="{{ inputLabelClass }}">Upload image</div>
            </div>

            <div class="{{ inputRowClass }} flex">
                <label for="recipe_image" class="file-label cursor-pointer overflow-hidden {{ btn_submit_inverse }}">
                    {{ include('component/_button_content.html.twig', {
                        icon: 'photo_size_select_small',
                        label: 'Choose file',
                    }) }}
                </label>
                {{ form_widget(form.image, {
                    attr: {'class': 'file-input hidden'},
                }) }}
            </div>
        </div>

        <div>
            {{ form_row(form.ingredients, {
                row_attr: {'class': textareaRowClass},
                label_attr: {'class': textareaLabelClass},
                attr: {'class': textareaClass, 'rows': 10},
            }) }}

            {{ form_row(form.instructions, {
                row_attr: {'class': 'mb-2'},
                label_attr: {'class': textareaLabelClass},
                attr: {'class': textareaClass, 'rows': 10},
            }) }}

            <div class="text-xs mb-6">
                <span class="font-semibold">Hint:</span> 
                Seperate each step with a new line!
            </div>
        
            <div class="flex justify-end">
                {{ include('component/_button_submit.html.twig', {
                    icon: 'add',
                    label: 'Save recipe',
                }) }}
            </div>
        </div>

        {{ form_row(form._token) }}
    {{ form_end(form) }}
{% endblock %}