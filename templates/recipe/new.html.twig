{# templates/recipe/new.html.twig #}

{% extends 'base.html.twig' %}
{% set heading = 'Add new recipe' %}


{% block main %}
<div class="flex">
    <div class="rounded-b-3xl md:rounded-3xl shadow-md border border-gray-200  bg-white mx-auto p-6 md:mt-10 lg:mt-20 w-full md:w-1/2">

        {{ form_start(form) }}
            {{ form_row(form.title, {
                row_attr: {'class': 'mb-6'},
                label_attr: {'class': 'text-sm font-semibold block mb-2'},
                attr: {'class': 'border rounded-full h-10 px-6 shadow-sm w-full'},
            }) }}

            {{ form_row(form.portionSize, {
                row_attr: {'class': 'mb-6'},
                label_attr: {'class': 'text-sm font-semibold block mb-2'},
                attr: {'class': 'border rounded-full h-10 px-6 shadow-sm w-24', 'min': 1},
            }) }}
            
            <div class="flex justify-between items-center">
                <div></div>
                <button type="submit" class="transition rounded-full w-32 h-10 px-6 shadow-md bg-violet-600 hover:bg-violet-500 hover:scale-110 font-semibold text-white">
                    Save
                </button>
            </div>

            {{ form_row(form._token) }}
        {{ form_end(form) }}
    </div>
</div>

<div class="flex">
    <div class="mx-auto p-6 md:mb-10 lg:mb-20 w-full md:w-1/2">
        <a href="{{ path('app_recipe_index') }}" class="transition duration-700 text-slate-400 hover:text-slate-600">Back to recipe list</a>
    </div>
</div>
    {{ include('component/_heading.html.twig', {heading: heading}) }}
{% endblock %}