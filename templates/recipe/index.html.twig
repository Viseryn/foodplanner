{% extends 'base.html.twig' %}

{% block title %}Recipe index{% endblock %}

{% block main %}
<div class="flex">
    <div class="rounded-b-3xl md:rounded-3xl shadow-md border border-gray-200  bg-white mx-auto p-6 md:mt-10 lg:mt-20 w-full md:w-1/2">
        <div class="text-xl font-semibold text-violet-700 mb-6">
            Recipes
        </div>

        <div class="overflow-x-auto relative">
            <table class="table-fixed w-full text-sm text-left text-gray-500">
                <thead class="text-xs text-gray-700 bg-gray-100">
                    <tr>
                        <th class="py-3 px-6 rounded-l-lg w-1/12">#</th>
                        <th class="py-3 px-6 rounded-r-lg">Recipe</th>
                    </tr>
                </thead>
                <tbody>
                {% for recipe in recipes %}
                    <tr>
                        <td class="py-4 px-6"><a href="{{ path('app_recipe_show', {'id': recipe.id}) }}" class="transition duration-700 hover:text-gray-900">{{ recipe.id }}</a></td>
                        <td class="py-4 px-6"><a href="{{ path('app_recipe_show', {'id': recipe.id}) }}" class="transition duration-700 hover:text-gray-900">{{ recipe.title }}</a></td>
                    </tr>
                {% else %}
                    <tr>
                        <td class="py-4 px-6" colspan="3">No recipes found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="flex">
    <div class="mx-auto p-6 md:mb-10 lg:mb-20 w-full md:w-1/2">
        <a href="{{ path('app_recipe_new') }}" class="transition duration-700 text-slate-400 hover:text-slate-600">Add new recipe ...</a>
    </div>
</div>
{% endblock %}
