{# templates/_vars.html.twig #}

{# General variables #}
{% set foo = 'bar' %}

{# Input Widget #}
{% set inputClass = 'border border-gray-300 rounded-full h-10 px-6 shadow-sm w-full' %}
{% set inputLabelClass = 'text-sm font-semibold block mb-2' %}
{% set inputRowClass = 'mb-6' %}

{# Textarea Widget #}
{% set textareaClass = 'block border border-gray-300 rounded-xl px-4 py-2 shadow-sm w-full' %}
{% set textareaLabelClass = inputLabelClass %}
{% set textareaRowClass = inputRowClass %}



{# Output #}
{% block html %}{% endblock %}