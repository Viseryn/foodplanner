{#
 # Twig Variables
 #}

{# General variables #}

{# Input Widget #}
{% set inputClass = 'border rounded-full h-10 px-6 shadow-sm w-full' %}
{% set inputLabelClass = 'text-sm font-semibold block mb-2' %}
{% set inputRowClass = 'mb-6' %}

{# Textarea Widget #}
{% set textareaClass = 'block border border-gray-300 rounded-xl px-4 py-2 shadow-sm w-full' %}
{% set textareaLabelClass = inputLabelClass %}
{% set textareaRowClass = inputRowClass %}

{# BEGIN HTML #}
<!DOCTYPE html>
<html>
    <head>
        <!-- Metadata -->
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
        <link rel="icon" type="image/x-icon" href="{{ asset('img/favicon.png') }}" />
        <title>{% block title %}FoodPlanner{% endblock %}</title>
        
        <!-- Stylesheets -->
        {# Icons, custom #}
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@48,700,1,0" />
        {% block stylesheets %}{{ encore_entry_link_tags('app') }}{% endblock %}

        
    </head>

    <body>
    {% block body %}

            <header>
                {% block header %}
                    {{ include('navbar/_navbar.html.twig')}}
                {% endblock %}
            </header>


        <main>
            <div class="flex">
                <aside class="w-64 pt-16 min-h-screen">
                    <div class="px-3 pt-7 bg-gray-50 h-full fixed w-64">

                        {# Sidebar #}
                        {% block sidebar_top %}
                            <ul class="space-y-2">
                                <li>
                                    <a class="flex items-center p-2 text-base font-normal text-gray-900 rounded-xl transition duration-300 hover:bg-gray-100 group" href="{{ path('app_recipe_index') }}">
                                        <span class="material-symbols-rounded flex-shrink-0 text-gray-500 transition duration-300 group-hover:text-gray-900">soup_kitchen</span>
                                        <span class="ml-3 flex-1">List of recipes</span>
                                        {{ render(controller(
                                            'App\\Controller\\RecipeController::numberOfRecipes'
                                        ))}}
                                    </a>
                                </li>
                                <li>
                                    <a class="flex items-center p-2 text-base font-normal text-gray-900 rounded-xl transition duration-300 hover:bg-gray-100 group" href="{{ path('app_storage_index') }}">
                                        <span class="material-symbols-rounded flex-shrink-0 text-gray-500 transition duration-300 group-hover:text-gray-900">kitchen</span>
                                        <span class="ml-3">Pantry</span>
                                    </a>
                                </li>
                            </ul>
                        {% endblock %}

                        {# Optional sidebar items #}
                        {% block sidebar %}{% endblock %}

                    </div>
                </aside>

                <div class="flex-initial px-10 mt-8 py-16 text-gray-700" style="width: 700px">

                    {# Main Content #}
                    {% block main %}{% endblock %}

                </div>
            </div>
        </main>

        <footer>
            {% block footer %}{% endblock %}
        </footer>
    {% endblock %}

        <!-- JavaScript -->
        {# jQuery, feather, custom #}
        {% block javascripts %}{{ encore_entry_script_tags('app') }}{% endblock %}
    </body>
</html>
{# END HTML #}