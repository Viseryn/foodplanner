{# templates/instruction/edit.html.twig #}

{% extends 'base.html.twig' %}
{# {% extends 'component/_form.html.twig' %} #}
{% set heading = 'Edit instruction' %}

{% block title %}{{ heading }}{% endblock %}

{% block sidebar %}
    {{ include('sidebar/_sidebar_hline.html.twig') }}
    {{ include('sidebar/_sidebar_recipe.html.twig', {recipe: instruction.recipe}) }}
    {{ include('sidebar/_sidebar_hline.html.twig') }}
    {{ include('sidebar/_sidebar_add_recipe.html.twig') }}
    {{ include('sidebar/_sidebar_space.html.twig') }}
    {{ include('sidebar/_sidebar_back_to_recipe.html.twig', {recipe: instruction.recipe}) }}
    {{ include('sidebar/_sidebar_space.html.twig') }}
    <ul class="space-y-2">
        {{ include('sidebar/_sidebar_item_form.html.twig', {
            icon: 'delete',
            name: 'Delete instruction',
            path: path('app_instruction_delete', {'id': instruction.id}),
            id: instruction.id,
        }) }}
    </ul>
{% endblock %}

{% block main %}
    {{ include('component/_heading.html.twig', {heading: heading}) }}

    {{ form_start(form, {attr: {'style': 'width: 350px'}}) }}
        {{ form_row(form.instruction, {
            row_attr: {'class': textareaRowClass},
            label_attr: {'class': textareaLabelClass},
            attr: {'class': textareaClass, 'rows': 8},
        }) }}

        {{ include('component/_submit_button_right.html.twig', {icon: 'update', label: 'Save instruction'}) }}

        {{ form_row(form._token) }}
    {{ form_end(form) }}
{% endblock %}