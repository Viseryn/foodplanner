{% extends 'base.html.twig' %}

{% block title %}Instruction index{% endblock %}

{% block main %}
<div class="flex">
<div class="rounded-b-3xl md:rounded-3xl shadow-md border border-gray-200  bg-white mx-auto p-6 md:my-10 lg:my-20 w-full md:w-1/2">

    <div class="text-xl font-semibold text-violet-700 mb-6">
        Instructions
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Recipe</th>
                <th>Instruction</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for instruction in instructions %}
            <tr>
                <td>{{ instruction.id }}</td>
                <td>{{ instruction.recipe }}</td>
                <td>{{ instruction.instruction }}</td>
                <td>
                    <a href="{{ path('app_instruction_show', {'id': instruction.id}) }}">show</a>
                    <a href="{{ path('app_instruction_edit', {'id': instruction.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_instruction_new') }}">Create new</a>

</div>
</div>
{% endblock %}
