{# templates/instruction/new.html.twig #}

{% extends 'base.html.twig' %}
{% set heading = 'Add new instruction' %}

{% block title %}{{ heading }}{% endblock %}

{% block main %}
<div class="flex">
    <div class="rounded-b-3xl md:rounded-3xl shadow-md border border-gray-200  bg-white mx-auto p-6 md:mt-10 lg:mt-20 w-full md:w-1/2">

        {{ form_start(form) }}
            <div class="flex flex-row items-end">
                {{ form_row(form.instruction, {
                    row_attr: {'class': 'flex-1 mr-6'},
                    label_attr: {'class': 'text-sm font-semibold block mb-2'},
                    attr: {'class': 'border rounded-xl px-4 py-2 shadow-sm w-full', 'rows': 6},
                }) }}
    {{ include('component/_heading.html.twig', {heading: heading}) }}

                <button type="submit" class="text-violet-700 text-xl rounded-full transition duration-500 hover:bg-violet-200 inline-flex justify-center p-2 flex-none">
                    {# <span class="material-symbols-rounded">send</span> #}
                    <svg aria-hidden="true" class="w-6 h-6 rotate-90" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"></path></svg>
                </button>
            </div>

            {{ form_row(form._token) }}
        {{ form_end(form) }}
    </div>
</div>

<div class="flex">
    <div class="mx-auto p-6 md:mb-10 lg:mb-20 w-full md:w-1/2">
        <a href="{{ path('app_recipe_show', {'id': instruction.recipe.id}) }}" class="transition duration-700 text-slate-400 hover:text-slate-600">Back to recipe</a>
    </div>
</div>
{% endblock %}
