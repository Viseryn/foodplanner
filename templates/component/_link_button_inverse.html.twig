{# templates/component/_link_button_inverse.html.twig #}

<a href="{{ path|default('#') }}"
    class="rounded-full h-12 pl-4 pr-6 font-semibold text-md 
        transition duration-300 flex items-center
        active:scale-95
        text-blue-600 bg-gray-100 
        hover:bg-blue-200 active:bg-blue-300 active:text-blue-800">
    <span class="material-symbols-rounded">{{ icon|default('') }}</span>
    <span class="ml-3">{{ label|default('') }}</span>
</a>