{# templates/ingredient/new.html.twig #}

{% extends 'base.html.twig' %}
{% set heading = 'Add new ingredient' %}

{% block title %}{{ heading }}{% endblock %}

{% block sidebar %}
    {{ include('sidebar/_sidebar_hline.html.twig') }}
    {% if ingredient.storage %}
        {{ include('sidebar/_sidebar_add_storage.html.twig') }}
    {% elseif ingredient.recipe %}
        {{ include('sidebar/_sidebar_recipe.html.twig', {recipe: ingredient.recipe}) }}
        {{ include('sidebar/_sidebar_hline.html.twig') }}
        {{ include('sidebar/_sidebar_add_recipe.html.twig') }}
        {{ include('sidebar/_sidebar_space.html.twig') }}
        {{ include('sidebar/_sidebar_back_to_recipe.html.twig', {recipe: ingredient.recipe}) }}
    {% endif %}
{% endblock %}


{% block main %}
    {{ include('component/_heading.html.twig', {heading: heading}) }}

    {{ form_start(form, {attr: {'style': 'width: 350px'}}) }}
        {{ form_row(form.name, {
            row_attr: {'class': inputRowClass},
            label_attr: {'class': inputLabelClass},
            attr: {'class': inputClass},
        }) }}

        {{ form_row(form.quantity, {
            row_attr: {'class': inputRowClass},
            label_attr: {'class': inputLabelClass},
            attr: {'class': inputClass},
        }) }}
        
        {{ include('component/_submit_button_right.html.twig', {icon: 'add', label: 'Save ingredient'}) }}

        {{ form_row(form._token) }}
    {{ form_end(form) }}
{% endblock %}
