{% extends 'base.html.twig' %}

{% block title %}Ingredient index{% endblock %}

{% block main %}
<div class="flex">
<div class="rounded-b-3xl md:rounded-3xl shadow-md border border-gray-200  bg-white mx-auto p-6 md:my-10 lg:my-20 w-full md:w-1/2">

    <div class="text-xl font-semibold text-violet-700 mb-6">
        Ingredients
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>QuantityValue</th>
                <th>QuantityUnit</th>
                <th>Recipe</th>
                <th>Storage</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for ingredient in ingredients %}
            <tr>
                <td>{{ ingredient.id }}</td>
                <td>{{ ingredient.name }}</td>
                <td>{{ ingredient.quantityValue }}</td>
                <td>{{ ingredient.quantityUnit }}</td>
                <td>{{ ingredient.recipe }}</td>
                <td>{{ ingredient.storage }}</td>
                <td>
                    <a href="{{ path('app_ingredient_show', {'id': ingredient.id}) }}">show</a>
                    <a href="{{ path('app_ingredient_edit', {'id': ingredient.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_ingredient_new') }}">Create new</a>

</div>
</div>
{% endblock %}
