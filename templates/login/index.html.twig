{% extends 'base.html.twig' %}

{% block title %}Sign in{% endblock %}

{% block main %}
<div class="rounded-b-3xl md:rounded-3xl shadow-md border border-gray-200  bg-white mx-auto p-6 md:my-10 lg:my-20 md:w-96 self-center">

{% if app.user %}
    <div class="flex p-4 text-sm text-green-700 bg-green-100 rounded-full" role="alert">
        <svg aria-hidden="true" class="flex-shrink-0 inline w-5 h-5 mr-3 items-center" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path></svg>
        <span class="sr-only">Info</span>
        <div class="flex w-full justify-between">
            <span class="font-medium">You are successfully signed in!</span>
            <a href="{{ path('app_logout') }}">Sign out ...</a>
        </div>
    </div>

{% else %}
    <div class="text-xl font-semibold text-violet-700 mb-6">
        Sign in to FoodPlanner
    </div>
    <form action="{{ path('app_login') }}" method="post">
        <div class="mb-6">
            <label for="username" class="text-sm font-semibold block mb-2">Your username</label>
            <input type="text" id="username" name="_username" value="{{ last_username }}" placeholder="Username ..." class="border rounded-full h-10 px-6 shadow-sm w-full" />
        </div>
        <div class="mb-8">
            <label for="password" class="text-sm font-semibold block mb-2">Your password</label>
            <input type="password" id="password" name="_password" placeholder="••••••••" class="border rounded-full h-10 px-6 shadow-sm w-full" />
        </div>

        <div class="flex justify-between items-center">
            <div class="text-sm">
    	        <a href="#" class="transition duration-700 text-slate-400 hover:text-slate-600">Forgot your password?</a> <br /> 
                <a href="{{ path('app_register') }}" class="transition duration-700 text-slate-400 hover:text-slate-600">Sign up for FoodPlanner</a>
            </div>
            <button type="submit" class="transition rounded-full w-32 h-10 px-6 shadow-md bg-violet-600 hover:bg-violet-500 hover:scale-110 font-semibold text-white">Sign in</button>
        </div>

        <input type="hidden" name="_target_path" value="/login" />
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}" />
    </form>
{% endif %}

{% if error %}
    <div class="flex p-4 mt-6 text-sm text-red-700 bg-red-100 rounded-full" role="alert">
        <svg aria-hidden="true" class="flex-shrink-0 inline w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path></svg>
        <span class="sr-only">Info</span>
        <div>
            <span class="font-medium">{{ error.messageKey | trans(error.messageData, 'security') }}</span> Please try again.
        </div>
    </div>
{% endif %}

</div>
{% endblock %}

