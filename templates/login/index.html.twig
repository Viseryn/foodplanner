{% extends 'base.html.twig' %}

{% block title %}Sign in{% endblock %}

{% block sidebar %}
    {% if error %}
        <div class="flex p-4 mt-10 text-sm text-red-700 bg-red-100 rounded-3xl items-center" role="alert">
            <span class="material-symbols-rounded flex-shrink-0 inline mr-5">info</span>
            <div>
                <span class="font-medium">{{ error.messageKey | trans(error.messageData, 'security') }}</span> <br />
                Please try again.
            </div>
        </div>
    {% endif %}
{% endblock %}

{% block main %}

{% if app.user %}
    <div class="flex p-4 text-sm text-green-700 bg-green-100 rounded-3xl items-center" role="alert">
        <span class="material-symbols-rounded flex-shrink-0 inline mr-5">info</span>
        <div class="flex w-full justify-between">
            <span class="font-medium">You are successfully signed in!</span>
            <a href="{{ path('app_logout') }}">Sign out ...</a>
        </div>
    </div>

{% else %}
    <div class="text-2xl font-semibold text-blue-600 mb-10">
        Sign in to FoodPlanner
    </div>
    <form action="{{ path('app_login') }}" method="post" style="width: 350px">
        <div class="mb-6">
            <label for="username" class="text-sm font-semibold block mb-2">Your username</label>
            <input type="text" id="username" name="_username" value="{{ last_username }}" placeholder="Username ..." class="border rounded-full h-10 px-6 shadow-sm w-full" />
        </div>
        <div class="mb-8">
            <label for="password" class="text-sm font-semibold block mb-2">Your password</label>
            <input type="password" id="password" name="_password" placeholder="••••••••" class="border rounded-full h-10 px-6 shadow-sm w-full" />
        </div>

        <div class="flex justify-between items-center">
            <div class="text-sm">
    	        <a href="#" class="transition duration-700 text-slate-400 hover:text-slate-600">Forgot your password?</a> <br /> 
                <a href="{{ path('app_register') }}" class="transition duration-700 text-slate-400 hover:text-slate-600">Sign up for FoodPlanner</a>
            </div>
            <button type="submit" class="transition duration-300 rounded-full h-10 pl-4 pr-6 shadow-md bg-blue-600 hover:bg-blue-500 font-semibold text-white text-lg flex items-center">
                <span class="material-symbols-rounded">login</span>
                <span class="ml-3">Sign in</span>
            </button>
        </div>

        <input type="hidden" name="_target_path" value="/login" />
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}" />
    </form>
{% endif %}

{% endblock %}