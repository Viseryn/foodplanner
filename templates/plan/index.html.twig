{# templates/plan/index.html.twig #}

{% extends 'base.html.twig' %}
{% set heading = 'Weekly Planner' %}

{% block title %}{{ heading }}{% endblock %}

{% block sidebar_action %}
    {{ include('sidebar/_sidebar_action.html.twig', {
        path: path('app_plan_new'),
        icon: 'add',
    }) }}
{% endblock %}

{% block load_sidebar %}loadSidebar('planner');{% endblock %}

{% block main %}
    <div class="max-w-[1000px]">
        {{ include('component/_heading.html.twig', {heading: heading}) }}

        {% for day in days %}
            <a class="text-lg font-semibold text-blue-600 mb-4 block" href="{{ path('app_plan_new_for_day', {dayId: day.id}) }}">
                {{ day.weekday }}, {{ day.date }}
            </a>

            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 mb-10">
                {% for meal in day.meals %}
                    <div class="h-40 w-full shadow-md rounded-2xl border border-gray-200 transition duration-300 hover:scale-95 hover:shadow-lg hover:bg-gray-50">
                        {% if meal.recipe.image is not null %}
                            <a href="{{ path('app_recipe_show', {'id': meal.recipe.id}) }}" class="relative">
                                <div class="absolute bottom-4 px-6 text-white font-semibold text-xl z-10">{{meal.mealCategory}} for {{ meal.userGroup }}: {{ meal.recipe.title }}</div>
                                <img class="rounded-2xl h-40 w-full object-cover brightness-75" src="{{ asset(meal.recipe.image) }}" alt="{{ meal.recipe }}" />
                            </a>
                        {% else %}
                            <a href="{{ path('app_recipe_show', {'id': meal.recipe.id}) }}" class="h-full w-full p-6 font-semibold text-xl z-10 flex items-end">
                                <div>{{meal.mealCategory}} for {{ meal.userGroup }}: {{ meal.recipe.title }}</div>
                            </a>
                        {% endif %}
                    </div>
                {% else %}
                    <span class="text-gray-400"><a href="{{ path('app_plan_new_for_day', {dayId: day.id}) }}">Nothing planned yet!</a></span>
                {% endfor %}
            </div>
        {% endfor %}

        <div class="flex justify-end space-x-4 mt-6">
            {{ include('component/_button.html.twig', {
                path: path('app_meal_index'),
                icon: 'settings',
                label: 'Meal CRUD',
                inverse: true,
            }) }}
            {{ include('component/_button.html.twig', {
                path: path('app_day_index'),
                icon: 'settings',
                label: 'Day CRUD',
                inverse: true,
            }) }}
        </div>
        <div class="flex justify-end space-x-4 mt-6">
            {{ include('component/_button.html.twig', {
                path: path('app_day_new'),
                icon: 'add',
                label: 'Current week',
                inverse: true,
            }) }}
            {{ include('component/_button.html.twig', {
                path: path('app_day_new_next'),
                icon: 'add',
                label: 'Next week',
                inverse: true,
            }) }}
        </div>
        <div class="flex justify-end space-x-4 mt-6">
            {{ include('component/_button.html.twig', {
                path: path('app_day_delete_all'),
                icon: 'delete_sweep',
                label: 'Delete all days',
                inverse: true,
            }) }}
        </div>
    </div>
{% endblock %}
